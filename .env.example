# Copy this file to .env and fill in actual values
# .env is gitignored — never commit real credentials

# ── OpenSky Network ──────────────────────────────────────────────────────────
# Free account at https://opensky-network.org (optional — unauthenticated
# requests work but are rate-limited to ~10 req/min)
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# ── Mapbox ───────────────────────────────────────────────────────────────────
# Free token at https://account.mapbox.com (required for map to render)
VITE_MAPBOX_TOKEN=

# ── GCP (optional — only needed for cloud deployment, not local dev) ─────────
GCP_PROJECT_ID=qantas-tracker-dev
GCP_REGION=us-central1

# ── Local development ────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
DEBUG=true
ENVIRONMENT=development
